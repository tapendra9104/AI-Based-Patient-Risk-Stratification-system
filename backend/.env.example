APP_ENV=development
DATABASE_URL=sqlite:///patient_risk.db
MODEL_PATH=models/risk_model.joblib
MODEL_RANDOM_STATE=42
SYNTHETIC_DATASET_SIZE=6000
BENCHMARK_PATH=models/benchmark_metrics.json
REAL_DATASET_EXPORT_PATH=data/breast_cancer_dataset.csv
RISK_LOW_THRESHOLD=0.35
RISK_HIGH_THRESHOLD=0.70
ALLOWED_ORIGINS=http://localhost:5500,http://127.0.0.1:5500
AUTH_REQUIRED=true
MAX_PATIENT_LIST_LIMIT=200
MAX_AUDIT_LOG_LIMIT=200

ALERT_PROVIDER=console
ALERT_TARGET=oncall-doctor
API_KEYS_JSON={"demo-admin-key":{"actor_id":"admin-console","name":"Demo Admin","role":"admin"},"demo-clinician-key":{"actor_id":"clinician-console","name":"Demo Clinician","role":"clinician"},"demo-analyst-key":{"actor_id":"quality-analyst","name":"Demo Analyst","role":"analyst"},"demo-ingest-key":{"actor_id":"integration-gateway","name":"Demo Integration","role":"ingest"}}

# Twilio WhatsApp (optional)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=
TWILIO_WHATSAPP_TO=
