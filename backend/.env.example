# ============================================
# Backend Environment Variables
# ============================================
# Copy this to .env and fill in your values

# MongoDB connection (use MongoDB Atlas for production)
# Free tier: https://www.mongodb.com/cloud/atlas/register
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/patient_risk_db

# Server port (Render sets this automatically via $PORT)
PORT=5000

# AI service URL (set this to your deployed AI service URL on Render)
AI_SERVICE_URL=http://localhost:8000

# Frontend URL for CORS (set to your deployed frontend URL)
FRONTEND_URL=https://riskai-frontend.onrender.com

# JWT Secret (Render auto-generates this)
JWT_SECRET=your-secret-key-here

# Auth mode (set to "true" for production)
AUTH_ENABLED=false

# Environment
NODE_ENV=production
